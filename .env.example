# =============================================================================
# News Hub - FREE AI-Generated News Reels with Oggy & Jack
# All services used here have FREE tiers or are completely free
# =============================================================================

# ─── AI Services (FREE) ───────────────────────────────────────────────
# Option 1: Groq API - 30,000 tokens/day FREE (recommended)
GROQ_API_KEY=gsk-xxxxx

# Option 2: Use local Ollama instead (no API key needed, install from https://ollama.ai)
# Set this to "true" to use Ollama instead of Groq
USE_OLLAMA=false

# ─── Social Media: YouTube (FREE tier: 10,000 units/day) ────────────────
YOUTUBE_CLIENT_ID=xxxxx.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=GOCSPX-xxxxx
YOUTUBE_ACCESS_TOKEN=xxxxx
YOUTUBE_REFRESH_TOKEN=xxxxx

# ─── Social Media: X/Twitter (FREE via OAuth 1.0a) ────────────────────
X_API_KEY=xxxxx
X_API_SECRET=xxxxx
X_ACCESS_TOKEN=xxxxx
X_ACCESS_TOKEN_SECRET=xxxxx

# ─── Social Media: Instagram (FREE via Instaloader) ────────────────────
# Instaloader uses username/password (not recommended for production)
# For better security, use a dedicated Instagram account
IG_USERNAME=your_instagram_username
IG_PASSWORD=your_instagram_password

# Alternative: Use session file (more secure)
# 1. Run: instaloader --login YOUR_USERNAME
# 2. It will save session to ~/.config/instaloader/sessionfile
# 3. No need to set IG_USERNAME/IG_PASSWORD

# ─── Social Media: Facebook (FREE via Graph API) ───────────────────────
FB_PAGE_ID=xxxxx
FB_ACCESS_TOKEN=xxxxx

# ─── Pipeline Settings ──────────────────────────────────────────────────
NEWS_SOURCES=google_news,ndtv,the_hindu
REELS_PER_DAY=3
REEL_SCHEDULE_TIMES=08:00,14:00,19:00
OUTPUT_DIR=output
LOG_LEVEL=INFO

# ─── Notes ────────────────────────────────────────────────────────────
# 1. All services listed above have FREE tiers
# 2. YouTube: 10,000 units/day = ~100+ uploads
# 3. Groq: 30,000 tokens/day = ~50-100 scripts (depending on length)
# 4. Twitter/X: OAuth 1.0a is still FREE (legacy API)
# 5. Instagram: Instaloader is unofficial but FREE
# 6. Facebook: Graph API is FREE with business verification
# 7. Edge TTS: Completely FREE (Microsoft Edge required)
# 8. RSS feeds: Completely FREE
#
# Total cost: $0 (with free tier limits)
